<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_order_portal_content_hotel_check_in_out"
              inherit_id="sale.sale_order_portal_content">
        <xpath expr="//tbody[@id='sale_info_table']" position="inside">
            <tr t-if="sale_order.hotel_check_in">
                <th class="ps-0 pb-0">Check In:</th>
                <td class="w-100 pb-0 text-wrap">
                    <span t-field="sale_order.hotel_check_in" t-options='{"widget": "datetime"}'/>
                </td>
            </tr>
            <tr t-if="sale_order.hotel_check_out">
                <th class="ps-0 pb-0">Check Out:</th>
                <td class="w-100 pb-0 text-wrap">
                    <span t-field="sale_order.hotel_check_out" t-options='{"widget": "datetime"}'/>
                </td>
            </tr>
        </xpath>
    </template>
</odoo>
